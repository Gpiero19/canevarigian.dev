# GitHub personal access token (optional — raises API rate limit from 60 to 5000 req/hr)
# Get yours at: https://github.com/settings/tokens (scopes: public_repo)
GITHUB_TOKEN=

# Canonical site URL — set to https://canevarigian.dev in production
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel Blob public URL for resume PDF (upload via Vercel dashboard → Storage → Blob)
NEXT_PUBLIC_RESUME_URL=
